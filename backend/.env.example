# Environment Variables
PORT=5000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/spatial_social_network

# JWT Secret (تغييره في الإنتاج)
JWT_SECRET=your_super_secret_jwt_key_please_change_this_in_production_12345

# Mapbox Token (احصل عليه من mapbox.com)
MAPBOX_TOKEN=pk.your_mapbox_access_token_here

# CORS Settings
CLIENT_URL=http://localhost:5173

# Upload Settings
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
