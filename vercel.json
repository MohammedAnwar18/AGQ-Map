{
  "version": 2,
  "functions": {
    "backend/server.js": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/server.js" },
    { "source": "/auth/(.*)", "destination": "/backend/server.js" },
    { "source": "/users/(.*)", "destination": "/backend/server.js" },
    { "source": "/shops/(.*)", "destination": "/backend/server.js" },
    { "source": "/posts/(.*)", "destination": "/backend/server.js" },
    { "source": "/ai/(.*)", "destination": "/backend/server.js" },
    { "source": "/notifications/(.*)", "destination": "/backend/server.js" },
    { "source": "/news/(.*)", "destination": "/backend/server.js" },
    { "source": "/communities/(.*)", "destination": "/backend/server.js" },
    { "source": "/admin/(.*)", "destination": "/backend/server.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
