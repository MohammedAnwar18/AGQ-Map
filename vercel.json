  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/auth/(.*)", "destination": "/api/index.js" },
    { "source": "/users/(.*)", "destination": "/api/index.js" },
    { "source": "/friends/(.*)", "destination": "/api/index.js" },
    { "source": "/shops/(.*)", "destination": "/api/index.js" },
    { "source": "/posts/(.*)", "destination": "/api/index.js" },
    { "source": "/comments/(.*)", "destination": "/api/index.js" },
    { "source": "/ai/(.*)", "destination": "/api/index.js" },
    { "source": "/notifications/(.*)", "destination": "/api/index.js" },
    { "source": "/news/(.*)", "destination": "/api/index.js" },
    { "source": "/communities/(.*)", "destination": "/api/index.js" },
    { "source": "/admin/(.*)", "destination": "/api/index.js" },
    { "source": "/health", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
