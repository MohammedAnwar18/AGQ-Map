{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "source": "/users/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "source": "/shops/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "source": "/posts/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "source": "/ai/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "source": "/notifications/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "source": "/news/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "source": "/communities/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/client/dist/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/client/dist/index.html"
    }
  ]
}
